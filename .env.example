# Recommended profiles:
# 1) Local quick start: DB_MODE=sqlite, USE_REDIS=False
# 2) Production/staging: DB_MODE=postgres, USE_REDIS=True

# Django
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
# Docker + 域名部署时，优先设置 SITE_DOMAINS，例如 bias.chat,www.bias.chat
SITE_DOMAINS=
SITE_SCHEME=https
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_MODE=sqlite
SQLITE_NAME=db.sqlite3
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bias
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
USE_REDIS=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Leave blank to follow the defaults implied by USE_REDIS.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@bias.local

# JWT
JWT_SECRET_KEY=jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# Frontend & CORS
# 正式域名场景优先使用 SITE_DOMAINS；下面三项仅在高级场景下需要手动覆盖
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Media & Static
MEDIA_URL=/media/
STATIC_URL=/static/
